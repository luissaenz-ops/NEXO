                </div>

                <div class="bg-slate-700 p-6 rounded-xl border-b-4 border-purple-400 hover:bg-slate-600 transition-colors">
                    <div class="text-4xl mb-4">🎓</div>
                    <h4 class="text-xl font-bold mb-2 text-purple-300">Red de Mentorías</h4>
                    <p class="text-sm text-slate-300">Vinculación directa de estudiantes con egresados exitosos para orientación personalizada sobre decisiones profesionales.</p>
                </div>

            </div>
        </section>

        <!-- SECCIÓN 4: ASISTENTE LLM (GEMINI API) -->
        <section class="bg-gradient-to-br from-blue-50 to-purple-50 rounded-2xl shadow-lg p-8 border-t-4 border-purple-500">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
                <div>
                    <h3 class="text-3xl font-bold text-purple-700 flex items-center">
                        Asistente de Carreras NEXO ✨
                    </h3>
                    <p class="text-md mt-2 text-slate-600 max-w-2xl">
                        En NEXO creemos en usar la mejor tecnología para tu beneficio. Probá nuestra IA impulsada por Gemini. Contanos qué estudiás o cuál es tu meta laboral, y te daremos un plan de acción rápido y personalizado.
                    </p>
                </div>
                <div class="text-5xl mt-4 md:mt-0">🚀</div>
            </div>

            <div class="bg-white p-6 rounded-xl shadow-sm border border-purple-100">
                <label for="careerInput" class="block text-sm font-medium text-slate-700 mb-2">¿Cuál es tu carrera y tu mayor desafío profesional actual?</label>
                <textarea id="careerInput" rows="3" class="w-full p-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition-all outline-none" placeholder="Ej: Estudio Marketing en línea desde Boston y quiero saber cómo conseguir pasantías remotas en agencias digitales..."></textarea>
                
                <div class="mt-4 flex items-center space-x-4">
                    <button id="generateAiBtn" onclick="generateCareerPlan()" class="bg-purple-600 hover:bg-purple-700 text-white font-bold py-2 px-6 rounded-lg shadow transition-colors flex items-center">
                        Generar Plan de Acción ✨
                    </button>
                    <span id="aiErrorMsg" class="text-rose-500 text-sm hidden font-medium">¡Por favor escribí algo en el cuadro de texto!</span>
                </div>

                <!-- AI Output Container -->
                <div id="aiOutputContainer" class="mt-6 hidden">
                    <h4 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-3">Tu Plan Personalizado NEXO:</h4>
                    <div class="bg-purple-50 border border-purple-200 rounded-lg p-5">
                        <div id="aiOutputText" class="text-slate-700 leading-relaxed space-y-2">
                            <!-- LLM Response will be injected here -->
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECCIÓN 5: EQUIPO -->
        <section class="bg-white rounded-2xl shadow-lg p-8 border-t-4 border-emerald-500">
            <h3 class="text-3xl font-bold mb-8 text-center text-emerald-700">El Equipo NEXO</h3>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-6 text-center">
                <div class="p-4">
                    <img src="Luis Larios.jpeg" alt="Luis Larios" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-blue-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Luis+Larios&background=DBEAFE&color=1E40AF';">
                    <h4 class="font-bold text-lg text-slate-800">Luis Larios</h4>
                    <p class="text-sm text-emerald-600 font-semibold">Presidente</p>
                </div>
                <div class="p-4">
                    <img src="Yuliana Gonzalez.jpeg" alt="Yuliana González" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-amber-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Yuliana+Gonzalez&background=FEF3C7&color=D97706';">
                    <h4 class="font-bold text-lg text-slate-800">Yuliana González</h4>
                    <p class="text-sm text-emerald-600 font-semibold">Vicepresidenta</p>
                </div>
                <div class="p-4">
                    <img src="Mariangely Benavente.jpeg" alt="Mariangely Benavente" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-purple-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Mariangely+Benavente&background=F3E8FF&color=7E22CE';">
                    <h4 class="font-bold text-lg text-slate-800">Mariangely Benavente</h4>
                    <p class="text-sm text-emerald-600 font-semibold">Dir. Comunicaciones</p>
                </div>
                <div class="p-4">
                    <img src="Grethel Quiñonez.jpeg" alt="Grethel Quiñonez" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-rose-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Grethel+Quiñonez&background=FFE4E6&color=BE123C';">
                    <h4 class="font-bold text-lg text-slate-800">Grethel Quiñonez</h4>
                    <p class="text-sm text-emerald-600 font-semibold">Vocera</p>
                </div>
                <div class="p-4">
                    <img src="Cesia Moreno.jpeg" alt="Cesia Moreno" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-emerald-100" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Cesia+Moreno&background=D1FAE5&color=047857';">
                    <h4 class="font-bold text-lg text-slate-800">Cesia Moreno</h4>
                    <p class="text-sm text-emerald-600 font-semibold">Tesorera</p>
                </div>
                <div class="p-4">
                    <img src="Denisse Navarro.jpeg" alt="Denisse Navarro" class="w-24 h-24 rounded-full mx-auto mb-3 shadow-md object-cover border-4 border-slate-200" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=Denisse+Navarro&background=E2E8F0&color=334155';">
