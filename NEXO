            </div>
        </section>

    </main>

    <footer class="bg-slate-900 text-slate-400 text-center py-8 mt-8">
        <p class="font-medium text-slate-300">VOTA NEXO - Por una universidad global e inclusiva</p>
        <p class="text-sm mt-2">Valores: Transparencia • Liderazgo • Inclusión • Responsabilidad • Trabajo en equipo</p>
    </footer>

    <!-- Script de la IA con Gemini API -->
    <script>
        // Recuerda colocar tu API key aquí antes de subirlo a Netlify
        const apiKey = ""; 

        async function fetchGeminiResponse(promptText) {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            
            const systemPrompt = `Eres el "Asistente de Carreras NEXO", una Inteligencia Artificial creada por el partido estudiantil NEXO de Keiser University (liderado por Luis Larios). 
            Tu misión es ayudar a los estudiantes a reducir la brecha entre su formación académica y el mundo laboral. 
            Tono: Amigable, motivador, usas 'vos' (estilo nicaragüense/latinoamericano), profesional pero juvenil.
            Instrucción: El usuario te dirá qué estudia y/o su meta laboral. Debes responder con un plan de acción MUY BREVE de 3 puntos: 
            1) Una habilidad clave que deben aprender. 
            2) Un consejo práctico para su CV o LinkedIn. 
            3) Un consejo de networking o búsqueda de empleo. 
            Mantén la respuesta en un solo párrafo o lista corta. Usa emojis.`;

            const payload = {
                contents: [{ parts: [{ text: promptText }] }],
                systemInstruction: { parts: [{ text: systemPrompt }] }
            };

            const delays = [1000, 2000, 4000, 8000, 16000];
            
            for (let attempt = 0; attempt < 6; attempt++) {
                try {
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    
                    if (!response.ok) {
                        throw new Error(`Error HTTP: ${response.status}`);
                    }
                    
                    const data = await response.json();
                    return data.candidates?.[0]?.content?.parts?.[0]?.text || "Lo siento, no pude generar un plan en este momento.";
                    
                } catch (error) {
                    if (attempt === 5) {
                        console.error("Fallo definitivo de la API:", error);
                        return "Hubo un problema de conexión con nuestros servidores de IA. ¡Por favor intentá de nuevo más tarde!";
                    }
                    await new Promise(resolve => setTimeout(resolve, delays[attempt]));
                }
            }
        }

        async function generateCareerPlan() {
            const inputEl = document.getElementById('careerInput');
            const btnEl = document.getElementById('generateAiBtn');
            const errorMsg = document.getElementById('aiErrorMsg');
            const outputContainer = document.getElementById('aiOutputContainer');
            const outputText = document.getElementById('aiOutputText');

            const userText = inputEl.value.trim();

            if (!userText) {
                errorMsg.classList.remove('hidden');
                inputEl.classList.add('border-rose-500');
                return;
            }
            
            errorMsg.classList.add('hidden');
            inputEl.classList.remove('border-rose-500');

            btnEl.disabled = true;
            btnEl.innerHTML = '<span class="loader"></span> Procesando...';
            outputContainer.classList.remove('hidden');
            outputText.innerHTML = '<span class="text-purple-600 font-medium animate-pulse">Consultando tu futuro con el banco de oportunidades NEXO... ⏳</span>';

            const llmResponse = await fetchGeminiResponse(`Estudiante dice: "${userText}". Generá mi plan de acción NEXO.`);

            const formattedHTML = llmResponse
                .replace(/\*\*(.*?)\*\*/g, '<strong class="text-purple-800">$1</strong>')
                .replace(/\n/g, '<br>');

            outputText.innerHTML = formattedHTML;

            btnEl.disabled = false;
            btnEl.innerHTML = 'Generar Plan de Acción ✨';
        }
    </script>

    <!-- Script de Chart.js para las gráficas -->
    <script>
        function wrapLabel(label) {
            if (label.length <= 16) return label;
            let words = label.split(' ');
            let lines = [];
            let currentLine = '';
            words.forEach(word => {
                if ((currentLine + word).length > 16) {
                    if (currentLine) lines.push(currentLine.trim());
                    currentLine = word + ' ';
                } else {
                    currentLine += word + ' ';
                }
            });
            if (currentLine) lines.push(currentLine.trim());
            return lines;
        }

        document.addEventListener('DOMContentLoaded', function() {
            
            const rawDiagLabels = [
                "Actividades poco interesantes",
                "Sin preparación laboral",
                "Falta de información",
                "Estrés académico",
                "Poca participación institucional"
            ];
            const diagData = [70, 68, 65, 60, 55];
            const processedDiagLabels = rawDiagLabels.map(wrapLabel);

            const ctxDiag = document.getElementById('diagnosisChart').getContext('2d');
            new Chart(ctxDiag, {
                type: 'bar',
                data: {
                    labels: processedDiagLabels,
                    datasets: [{
                        label: '% de Estudiantes Afectados',
                        data: diagData,
                        backgroundColor: ['#EF4444', '#F59E0B', '#2563EB', '#8B5CF6', '#10B981'],
                        borderWidth: 0,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                title: function(tooltipItems) {
                                    const item = tooltipItems[0];
                                    let label = item.chart.data.labels[item.dataIndex];
                                    return Array.isArray(label) ? label.join(' ') : label;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100,
                            grid: { color: '#E2E8F0' },
                            ticks: { callback: function(value) { return value + '%'; } }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: { size: 11 } }
                        }
                    }
                }
            });

            const rawInfoLabels = ["Desinformados sobre oportunidades", "Informados adecuadamente"];
            const processedInfoLabels = rawInfoLabels.map(wrapLabel);

            const ctxInfo = document.getElementById('infoGapChart').getContext('2d');
            new Chart(ctxInfo, {
                type: 'doughnut',
                data: {
                    labels: processedInfoLabels,
                    datasets: [{
                        data: [65, 35],
                        backgroundColor: ['#F59E0B', '#E2E8F0'],
                        hoverOffset: 4,
                        borderWidth: 2,
                        borderColor: '#ffffff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 20, font: { size: 13 } }
                        },
                        tooltip: {
                            callbacks: {
                                title: function(tooltipItems) {
                                    const item = tooltipItems[0];
                                    let label = item.chart.data.labels[item.dataIndex];
                                    return Array.isArray(label) ? label.join(' ') : label;
                                },
                                label: function(context) {
                                    return ' ' + context.parsed + '% de estudiantes';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
</body>
